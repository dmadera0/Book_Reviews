  "item": [
    {
      "name": "Books",
      "item": [
        {
          "name": "Create Book",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Response has a bookId field\", function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property(\"bookId\");",
                  "});",
                  "",
                  "pm.test(\"Response title equals Dune\", function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.title).to.eql(\"Dune\");",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set(\"bookId\", json.bookId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Dune\",\n  \"author\": \"Frank Herbert\",\n  \"genre\": \"Sci-Fi\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/books",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "books"
              ]
            }
          },
          "response": []
        },
